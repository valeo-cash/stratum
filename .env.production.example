NODE_ENV=production
PORT=3100

# Database
DATABASE_URL=postgresql://stratum:<password>@<host>:5432/stratum
POSTGRES_PASSWORD=<strong-password>

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ANCHOR_PROGRAM_ID=<mainnet-program-id>
SOLANA_PRIVATE_KEY=<base64-encoded-keypair>

# Multi-chain settlement
SOLANA_SETTLEMENT_KEY=<base64-encoded-keypair>
SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
BASE_RPC_URL=https://mainnet.base.org
BASE_SETTLEMENT_KEY=<0x-private-key>
BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Security
REQUIRE_API_KEYS=true
ENABLE_PREFLIGHT_CHECK=true

# CORS (comma-separated origins)
CORS_ORIGINS=https://stratum.valeo.com,https://*.vercel.app

# Settlement timing
SETTLEMENT_INTERVAL_SECONDS=60
