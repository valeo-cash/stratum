{
  "name": "valeo-stratum",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "demo": "pnpm --filter @valeo/simulator start",
    "build:gateway": "pnpm --filter @valeo/gateway... build",
    "start:gateway": "node apps/gateway/dist/index.js",
    "db:migrate:prod": "cd apps/gateway && npx prisma migrate deploy"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.98.0",
    "dotenv": "^17.3.1"
  }
}
