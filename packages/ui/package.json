{
  "name": "@valeo/ui",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tailwind": {
      "import": "./dist/tailwind.mjs",
      "require": "./dist/tailwind.js",
      "types": "./dist/tailwind.d.ts"
    },
    "./globals.css": "./src/globals.css"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/react": "^18",
    "tsup": "^8",
    "vitest": "^2",
    "tailwindcss": "^3.4.1"
  }
}
