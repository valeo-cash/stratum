# Database
DATABASE_URL=postgresql://stratum:stratum@localhost:5432/stratum

# Redis
REDIS_URL=redis://localhost:6379

# Solana RPC
SOLANA_RPC_URL=https://api.devnet.solana.com

# Anchor program ID (deployed stratum-anchor program)
ANCHOR_PROGRAM_ID=<deployed-program-id>

# Base58-encoded Solana keypair for anchoring Merkle roots on-chain
SOLANA_PRIVATE_KEY=<base58-keypair-for-anchoring>

# Base58-encoded Solana keypair for settlement authority (SPL token delegate)
SOLANA_SETTLEMENT_KEY=<base58-keypair-for-settlement-authority>

# Devnet USDC mint address (Solana SPL token for testing)
SOLANA_USDC_MINT=<devnet-usdc-mint-address>

# Base (EVM) settlement config
BASE_RPC_URL=https://sepolia.base.org
BASE_SETTLEMENT_KEY=<0x-private-key-for-settlement>
BASE_USDC_ADDRESS=<usdc-contract-address-on-base>

# Enable pre-flight balance/allowance checks before accepting payments
ENABLE_PREFLIGHT_CHECK=false

# x402 Facilitator (default: Coinbase)
FACILITATOR_URL=https://x402.org/facilitator

# Settlement window duration in seconds (default: 5 minutes)
SETTLEMENT_WINDOW_SECONDS=300

# Ed25519 private key for signing receipts (hex-encoded)
STRATUM_SIGNING_KEY=
